    id INTEGER PRIMARY KEY AUTOINCREMENT,
    make TEXT NOT NULL,
    model TEXT NOT NULL,
    category TEXT NOT NULL,
    part_name TEXT NOT NULL,
    article TEXT NOT NULL,
    resource_km INTEGER NOT NULL
);

